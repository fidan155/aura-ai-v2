# Kopieren nach .env und mit echten Werten füllen.
# Für lokale Entwicklung ohne Docker (start-local.sh, eigener Postgres-Container)
DATABASE_URL=postgres://postgres:geheim@127.0.0.1:5432/pk_db

# Zufälligen Wert generieren, z. B.: openssl rand -hex 32
JWT_SECRET=

# Nur für den docker-compose-Stack (postgres/frontend/studio-Service)
# Zufälligen Wert generieren, z. B.: openssl rand -hex 24
POSTGRES_PASSWORD=

# Python FastAPI Microservice im Docker-Netzwerk
PYTHON_API_URL=http://backend:8000
